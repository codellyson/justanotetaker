{
  "name": "@codellyson/justanotetaker-mcp",
  "version": "0.2.1",
  "description": "MCP server for Just a Notetaker — lets any MCP client (Claude, etc.) list, create, update, and delete boards and notes on your canvas, read boards as conversations, and reply as an agent.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codellyson/justanotetaker.git",
    "directory": "packages/mcp-server"
  },
  "homepage": "https://justanotetaker.kreativekorna.com/mcp",
  "bugs": "https://github.com/codellyson/justanotetaker/issues",
  "bin": {
    "justanotetaker-mcp": "dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "notes",
    "canvas",
    "justanotetaker"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "watch": "node dist/index.js watch",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22",
    "tsx": "^4.19.0",
    "typescript": "^5"
  }
}
