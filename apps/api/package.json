{
  "name": "@justnotes/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "deploy": "wrangler deploy",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply justnotes-dev --local",
    "db:migrate:remote": "wrangler d1 migrations apply justnotes-prod --remote",
    "auth:generate": "better-auth generate --config src/auth.ts --output src/db/schema.ts"
  },
  "dependencies": {
    "better-auth": "^1.2.0",
    "drizzle-orm": "^0.36.0",
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250101.0",
    "@types/node": "^20",
    "drizzle-kit": "^0.28.0",
    "typescript": "^5",
    "wrangler": "^3.95.0"
  }
}
