{
  "name": "justanotetaker-monorepo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @justanotetaker/web dev",
    "dev:api": "pnpm --filter @justanotetaker/api dev",
    "dev:marketing": "pnpm --filter @justanotetaker/marketing dev",
    "db:migrate": "pnpm --filter @justanotetaker/api db:migrate:local",
    "db:migrate:remote": "pnpm --filter @justanotetaker/api db:migrate:remote",
    "db:migrate:create": "pnpm --filter @justanotetaker/api db:migrate:create",
    "build": "pnpm -r --parallel build",
    "lint": "pnpm -r --parallel lint",
    "tauri": "tauri",
    "tauri:dev": "cross-env WEBKIT_DISABLE_DMABUF_RENDERER=1 WEBKIT_DISABLE_COMPOSITING_MODE=1 WEBKIT_FORCE_SANDBOX=0 LIBGL_ALWAYS_SOFTWARE=1 tauri dev",
    "tauri:build": "tauri build",
    "release": "bash scripts/release.sh"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.2",
    "cross-env": "^10.1.0"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.14",
      "@types/react-dom": "19.2.3",
      "vite": "^6.0.0",
      "kysely": "^0.28.17"
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "workerd",
      "sharp",
      "@tauri-apps/cli"
    ]
  }
}
